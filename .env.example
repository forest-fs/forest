# Database (matches docker-compose postgres service on localhost for native runs)
# The `forest` service in docker-compose overrides this to host `postgres`.
DATABASE_URL=postgresql+asyncpg://forest:forest@localhost:5432/forest

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# HTTP (FastAPI / Uvicorn)
HOST=0.0.0.0
PORT=8000

# LLM — OpenAI-compatible HTTP API (default base URL = OpenRouter)
# Prefer these names:
LLM_API_KEY=
LLM_BASE_URL=https://openrouter.ai/api/v1
# Optional (e.g. OpenRouter attribution)
LLM_HTTP_REFERER=
LLM_APP_NAME=Forest
# Legacy aliases (same as LLM_*): OPENROUTER_API_KEY, OPENROUTER_BASE_URL, OPENROUTER_HTTP_REFERER, OPENROUTER_APP_NAME

CHAT_MODEL_ID=
# Must match DB vector dimension (768 by default; e.g. text-embedding-3-small + dimensions=768). See docs/llm-configuration.md.
EMBEDDING_MODEL_ID=

LOG_LEVEL=INFO

# Onboarding: message history scan → LLM (optional; defaults are in config.py)
# FOREST_ONBOARDING_HISTORY_PER_CHANNEL_CHARS=80000
# FOREST_ONBOARDING_HISTORY_TOTAL_CHARS=240000
# FOREST_ONBOARDING_HISTORY_OLDEST_FIRST=false
